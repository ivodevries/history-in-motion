{
  "name": "history-in-motion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:vite dev:pages",
    "dev:vite": "vite",
    "dev:pages": "wrangler pages dev ./dist",
    "build": "run-p build:vite",
    "build:vite": "vite build && node scripts/build-worker.js",
    "preview": "vite preview",
    "build:pages": "npm-run-all2 build:vite",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "deploy": "wrangler pages deploy dist --project-name=history-in-motion",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "maplibre-gl": "^5.21.1",
    "pinia": "^3.0.3",
    "pmtiles": "^4.4.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.32",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/eslint-plugin": "^1.2.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.2.7",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.5.3",
    "typescript": "~5.8.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.81.1"
  }
}